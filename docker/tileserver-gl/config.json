{
  "options": {
    "paths": {
      "root": "/data",
      "fonts": "fonts",
      "styles": "styles",
      "mbtiles": ""
    },
    "serveAllFonts": true,
    "maxScaleFactor": 3,
    "maxSize": 2048,
    "pbfAlias": "pbf",
    "formatQuality": {
      "jpeg": 80,
      "webp": 80
    }
  },
  "styles": {
    "osm-bright": {
      "style": "osm-bright-gl-style/style.json",
      "tilejson": {
        "type": "overlay",
        "bounds": [33.9, -4.7, 41.9, 5.5]
      }
    }
  },
  "data": {
    "kenya": {
      "mbtiles": "kenya.mbtiles"
    }
  }
}
